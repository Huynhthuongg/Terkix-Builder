{
  "name": "terkix-builder",
  "version": "1.0.0",
  "description": "A comprehensive IDE web platform with code editor, runtime environment, and build system",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:server\"",
    "dev:next": "next dev",
    "dev:server": "node server.js",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "import:repos": "node scripts/import-repositories.mjs"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.0.0",
    "@codemirror/lang-python": "^6.0.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@vercel/analytics": "^2.0.1",
    "ace-builds": "^1.20.0",
    "axios": "^1.4.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "codemirror": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "framer-motion": "^10.16.0",
    "lucide-react": "^0.263.0",
    "monaco-editor": "^0.44.0",
    "next": "^15.5.18",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.45.0",
    "recharts": "^2.7.0",
    "socket.io": "^4.6.0",
    "socket.io-client": "^4.6.0",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "^3.3.0",
    "zod": "^3.22.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.44.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.1.0"
